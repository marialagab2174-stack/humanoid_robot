</geometry>
<material name="grey"/>
</visual>
</link>
<joint name="torso_roll" type="revolute">
<origin xyz="0.027046 0.032 -0.057345" rpy="0 0 0"/>
<axis xyz="0 0 -1"/>
<parent link="torso_1"/>
<child link="torso_2"/>
<limit effort="50000" lower="-0.523599" upper="0.523599" velocity="50000"/>
</joint>
<link name="chest">
