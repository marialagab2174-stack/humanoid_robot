<robot name="iCub">
<!--
 =================== MATERIAUX =================== 
-->
<material name="grey">
<color rgba="0.75 0.75 0.75 1"/>
</material>
<material name="red">
</material>
<material name="white">
<color rgba="1 1 1 1"/>
</material>
<material name="dark">
<color rgba="0.15 0.15 0.15 1"/>
</material>
<material name="skin">
<color rgba="0.96 0.80 0.69 1"/>
</material>
<material name="black">
<color rgba="0.05 0.05 0.05 1"/>
</material>
<!-- =================== BASE =================== -->
<link name="base_link"/>
<link name="root_link">
<visual>
<origin xyz="-0.0364 0 0.032" rpy="1.5707963 0 -1.5707963"/>
<geometry>
<mesh filename="package://humanoid_robot/meshes/root.dae" scale="0.001 0.001 0.001"/>
</geometry>
<material name="grey"/>
</visual>
</link>
<joint name="base_link_fixed_joint" type="fixed">
<parent link="root_link"/>
<child link="base_link"/>
<origin xyz="0 0 0" rpy="0 0 0"/>
</joint>
<!-- =================== TORSE =================== -->
<link name="torso_1">
<visual>
<origin xyz="0.027046 0.032 0.0364" rpy="0 0 0"/>
