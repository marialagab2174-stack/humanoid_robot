<mesh filename="package://humanoid_robot/meshes/torso_1.dae" scale="0.001 0.001 0.001"/>
</geometry>
<material name="grey"/>
</visual>
</link>
<!--
 CORRECTION: torso_pitch — décalage vertical augmenté pour séparer du bassin 
-->
<joint name="torso_pitch" type="revolute">
<origin xyz="0 0.027046 0" rpy="1.5707963 0 -1.5707963"/>
<axis xyz="1 0 0"/>
<parent link="root_link"/>
<child link="torso_1"/>
<limit effort="50000" lower="-0.349066" upper="1.221730" velocity="50000"/>
</joint>
<link name="torso_2">
<visual>
<origin xyz="0 0.1433 0.038653" rpy="0 0 0"/>
